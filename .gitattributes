# Force LF line endings for source/text files so Windows Git doesn't inject CRLF.
*.sh text eol=lf
*.html text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.wasm binary
*.sqlite binary
*.sqlite-shm binary
*.sqlite-wal binary
*.png binary
*.jpg binary
*.jpeg binary
*.svg text
