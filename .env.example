# KasirGo — Environment Variables (dev)
# Copy file ini ke .env dan sesuaikan nilai

# Server port
PORT=3456

# Path database SQLite (relatif dari backend/)
DB_PATH=backend/db/kasirgo.sqlite

# Origin yang diizinkan untuk CORS (support multiple via comma)
# Dev: http://localhost:5173 (Vite dev server)
# Production: domain kamu (e.g. https://kasirgo.railway.app)
CORS_ORIGIN=http://localhost:5173

# Session cookie: berapa hari sampai expired
SESSION_DAYS=7

# Cookie Secure flag (true kalau pakai HTTPS)
COOKIE_SECURE=false

# Cookie Domain: set "localhost" untuk dev (cookie cross-port :5173 ↔ :3456)
# Production: kosongkan (cookie scoped ke origin domain sendiri)
COOKIE_DOMAIN=localhost

# Rate limiting login: max attempt per window
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000

# ============================================================
# Mail (Resend API — https://resend.com)
# ============================================================
# Dev: kosongkan RESEND_API_KEY → kode verifikasi / magic link di-log
# ke console backend (mode testing, tidak kirim email beneran).
# Production: isi dengan API key dari dashboard Resend.
RESEND_API_KEY=
MAIL_FROM=KasirGo <noreply@kasirgo.app>

# Public app URL (untuk magic link di email verification/reset)
# Dev: http://localhost:5173 (Vite dev server)
# Production: domain kamu (e.g. https://kasirgo.railway.app)
APP_URL=http://localhost:5173

# Email verification code expiry (menit)
VERIFY_CODE_EXPIRY_MIN=30

# Password reset code expiry (menit)
RESET_CODE_EXPIRY_MIN=15

# ============================================================
# Rate limiting auth flow
# ============================================================
# Signup: max attempt per IP per window (anti abuse signup)
RATE_LIMIT_SIGNUP_MAX=3
RATE_LIMIT_SIGNUP_WINDOW_MS=3600000

# Forgot password: max attempt per IP+email per window
RATE_LIMIT_FORGOT_MAX=3
RATE_LIMIT_FORGOT_WINDOW_MS=3600000

# Verify code attempts: max per IP per window (anti brute-force 8-digit code)
RATE_LIMIT_VERIFY_MAX=5
RATE_LIMIT_VERIFY_WINDOW_MS=60000

# hCaptcha (anti-bot di signup setelah attempt ke-2 dari IP yang sama)
# Daftar di https://dashboard.hcaptcha.com — dapat site key + secret.
# Dev: kosongkan → hCaptcha check di-skip (mode testing).
HCAPTCHA_SECRET=
HCAPTCHA_SITE_KEY=

# Dev mode: skip static file serving (frontend di-serve Vite, port 5173)
DEV_ENV=
