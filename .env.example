# KasirGo — Environment Variables
# Copy file ini ke .env dan sesuaikan nilai

# Server port
PORT=3456

# Path database SQLite (relatif dari backend/)
DB_PATH=backend/db/kasirgo.sqlite

# Origin yang diizinkan untuk CORS (production: domain kamu)
CORS_ORIGIN=http://localhost:3456

# Session cookie: berapa hari sampai expired
SESSION_DAYS=7

# Cookie Secure flag (true kalau pakai HTTPS)
COOKIE_SECURE=false

# Rate limiting login: max attempt per window
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000