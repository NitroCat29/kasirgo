# KasirGo Frontend — Environment example
# Copy ke .env lalu sesuaikan. Jangan commit .env (sudah di-gitignore).

# VITE_DEV_MODE=true  → dev TANPA backend (auth di-mock, captcha di-skip).
# VITE_DEV_MODE=false → produksi / kalau backend Bun jalan di :3456.
# Default aman: false (production-safe).
VITE_DEV_MODE=false

# Opsional: kalau backend di port/host lain (e.g. Railway deploy), set di sini.
# Kosong = same-origin (frontend served from backend).
# VITE_API_BASE=https://kasirgo.up.railway.app
